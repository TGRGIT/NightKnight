# Copy to .env for `docker compose up`. Do NOT commit your real .env.

# Postgres password (used by both the db and the app connection string).
POSTGRES_PASSWORD=change-me-please

# Host port to expose the app on.
NK_PORT=8787

# Identity resolution behind your reverse proxy:
#   trust-header  – read the user's email from NK_AUTH_HEADER (oauth2-proxy/APISIX)
#   dev           – a single fixed demo user (LOCAL DEVELOPMENT ONLY)
#   none          – device-token (api-secret/Bearer) auth only
NK_AUTH_MODE=trust-header
NK_AUTH_HEADER=x-auth-request-email

# Log filter (e.g. info, debug, nightknight_server=debug).
NK_LOG=info

# --- Optional CGM cloud connector (polls a vendor cloud and ingests readings) ---
# NK_CONNECTOR=dexcom | librelinkup | (unset = off)
# NK_CONNECTOR_USER=you@example.com      # NightKnight user the readings belong to
# NK_CONNECTOR_INTERVAL_SECS=300
# Dexcom Share:
# NK_DEXCOM_USERNAME=...
# NK_DEXCOM_PASSWORD=...
# NK_DEXCOM_REGION=us                    # us | ous | jp
# LibreLinkUp:
# NK_LLU_EMAIL=...
# NK_LLU_PASSWORD=...

# --- Optional silent push (APNs) for timely iOS background refresh ---------------
# Sends a background notification when a connector sync brings in fresh readings, so
# the app wakes and refreshes. Leave unset to disable (registration still works).
# Full guide + rollout: docs/SILENT-PUSH.md.
# The .p8 PEM is multi-line; in a single-line .env value, write the newlines as literal
# \n — the server un-escapes them. (Compose does NOT expand \n itself.) Quote the value:
# APNS_KEY_P8="-----BEGIN PRIVATE KEY-----\nMIG...\n...\n-----END PRIVATE KEY-----\n"
# APNS_KEY_ID=ABC1234DEF          # 10-char Key ID of the .p8 auth key
# APNS_TEAM_ID=XYZ9876WUV         # 10-char Apple Team ID
# APNS_BUNDLE_ID=be.cooney.nightknight.NightKnight
# APNS_DEFAULT_ENV=sandbox        # sandbox | production (per-token value wins)
