# Copy to .env for `docker compose up`. Do NOT commit your real .env.

# Postgres password (used by both the db and the app connection string).
POSTGRES_PASSWORD=change-me-please

# Host port to expose the app on.
NK_PORT=8787

# Identity resolution behind your reverse proxy:
#   trust-header  – read the user's email from NK_AUTH_HEADER (oauth2-proxy/APISIX)
#   dev           – a single fixed demo user (LOCAL DEVELOPMENT ONLY)
#   none          – device-token (api-secret/Bearer) auth only
NK_AUTH_MODE=trust-header
NK_AUTH_HEADER=x-auth-request-email

# Log filter (e.g. info, debug, nightknight_server=debug).
NK_LOG=info

# --- Optional CGM cloud connector (polls a vendor cloud and ingests readings) ---
# NK_CONNECTOR=dexcom | librelinkup | (unset = off)
# NK_CONNECTOR_USER=you@example.com      # NightKnight user the readings belong to
# NK_CONNECTOR_INTERVAL_SECS=300
# Dexcom Share:
# NK_DEXCOM_USERNAME=...
# NK_DEXCOM_PASSWORD=...
# NK_DEXCOM_REGION=us                    # us | ous | jp
# LibreLinkUp:
# NK_LLU_EMAIL=...
# NK_LLU_PASSWORD=...
